# Root env for the Docker Compose deploy (VPS).
# The easy path: run ./deploy.sh once — it generates this file with real
# secrets. This example only documents the variables.

# URL browsers use to reach each service (public IP or domain — NOT docker-internal)
NEXT_PUBLIC_API_URL=http://your-server-ip:4000
WEB_ORIGIN=http://your-server-ip:3000

# strong random strings (openssl rand -hex 32)
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh

# protected superadmin seeded on first boot
SUPERADMIN_USERNAME=sl106404
SUPERADMIN_PASSWORD=change_me_strong_password
SUPERADMIN_EMAIL=superadmin@local.host

# web push — npx web-push generate-vapid-keys (blank = push disabled)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@local.host

TRADING_LOSS_ALERT_THRESHOLD=100
